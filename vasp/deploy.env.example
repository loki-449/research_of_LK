# =============================================================================
# VASP 工作流部署配置模板
#
# 用法:
#   cp deploy.env.example deploy.env
#   vim deploy.env          # 若路径与 high-317 布局不同再改
#   source deploy.env       # 当前 shell 生效
#   或写入 ~/.bashrc: source /home/test1/hhy/high-317/vasp/deploy.env
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 脚本安装路径（deploy 目标，与计算数据无关）
# -----------------------------------------------------------------------------
export VASP_SCRIPTS_ROOT=/home/test1/hhy/high-317/vasp/scripts

# -----------------------------------------------------------------------------
# 2. 计算工作根目录（VASP 输入/输出数据存放处）
#    其下结构: <材料>/<压强>/opt/ 与 scf_ELF/ 并列
# -----------------------------------------------------------------------------
export VASP_WORK_ROOT=/home/test1/hhy/high-317/vasp_work

# -----------------------------------------------------------------------------
# 3. QE 前处理输入目录（opt 部署的数据来源）
# -----------------------------------------------------------------------------
export QE_ROOT=/home/test1/hhy/high-317/QE

# -----------------------------------------------------------------------------
# 4. 赝势库
# -----------------------------------------------------------------------------
export PBE_LIB=/home/test1/hhy/basic/psudopotential/PAW-GGA-PBE

# -----------------------------------------------------------------------------
# 5. Python 解释器（集群默认 python3）
# -----------------------------------------------------------------------------
export VASP_PYTHON=python3

# -----------------------------------------------------------------------------
# 6. PBS 提交控制（submit_opt.py 默认值可通过命令行覆盖）
# -----------------------------------------------------------------------------
export VASP_SUBMIT_MAX_JOBS=8
export VASP_SUBMIT_WAIT_INTERVAL=60

# -----------------------------------------------------------------------------
# 7. 可选：指向本配置文件，供脚本启动时自动 source（见 path_config.py）
# -----------------------------------------------------------------------------
export VASP_DEPLOY_ENV=/home/test1/hhy/high-317/vasp/deploy.env
