# opt 子模块专用配置（由 deploy.env 统一 source，或单独追加）
#
# 本文件列出的变量在 master deploy.env 中也可配置；
# 若需 opt 阶段特殊设置，可在 deploy.env 末尾追加:
#   source /path/to/scripts/opt/config.env

# PBS 队列并发上限（submit_opt.py --max-jobs 可覆盖）
export VASP_SUBMIT_MAX_JOBS=8

# 队列满时重试间隔（秒）
export VASP_SUBMIT_WAIT_INTERVAL=60

# QE 体系文件夹匹配模式（setup_opt_workflow.py --pattern 可覆盖）
export VASP_QE_PATTERN="*GPa*"
