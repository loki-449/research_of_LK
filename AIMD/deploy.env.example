# =============================================================================
# AIMD 部署配置模板（与 vasp/deploy.env 完全独立）
#
#   cp deploy.env.example deploy.env
#   source deploy.env
# =============================================================================

# 脚本安装根（本仓库 AIMD/scripts，或拷贝安装位置）
export AIMD_SCRIPTS_ROOT=/home/test1/hhy/high-317/AIMD/scripts

# 计算数据根：其下为 <A>/{opt,scf-MD,AIMD}/ 以及汇总目录
#   MSD_data_for_origin/   ← .dat
#   MSD_png/               ← png
export AIMD_WORK_ROOT=/home/test1/hhy/high-317/aimd_work

export AIMD_PYTHON=python3
export AIMD_DEPLOY_ENV=/home/test1/hhy/high-317/AIMD/deploy.env

# -----------------------------------------------------------------------------
# 关于「默认 dt」：不要设置静态 AIMD_DT_DEFAULT
# 每个体系运行时从 $AIMD_WORK_ROOT/<A>/AIMD/INCAR 读取 POTIM（单位 fs）。
# Time(ps) = frame_index * POTIM / 1000
# 若 CLI 显式 --dt，则覆盖 INCAR，并在与 POTIM 不一致时打印 WARNING。
# -----------------------------------------------------------------------------
